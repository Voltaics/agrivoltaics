    "version": "0.2.0",
    "configurations": [
        {
            "name": "agrivoltaics_flutter_app (mobile portrait)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}/application/agrivoltaics_flutter_app",
            "deviceId": "chrome",
            "toolArgs": [
                "--web-browser-flag=--new-window",
                "--web-browser-flag=--window-size=390,844",
                "--dart-define=AUTHORIZED_EMAILS=rindler.eli@gmail.com,nguye2cy@mail.uc.edu,voltaicstestuser1@gmail.com"
            ]
        },
        {
            "name": "agrivoltaics_flutter_app (mobile landscape)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}/application/agrivoltaics_flutter_app",
            "deviceId": "chrome",
            "toolArgs": [
                "--web-browser-flag=--new-window",
                "--web-browser-flag=--window-size=844,390",
                "--dart-define=AUTHORIZED_EMAILS=rindler.eli@gmail.com,nguye2cy@mail.uc.edu,voltaicstestuser1@gmail.com"
            ]
        },
        {
            "name": "agrivoltaics_flutter_app (desktop)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}/application/agrivoltaics_flutter_app",
            "deviceId": "chrome",
            "toolArgs": [
                "--web-browser-flag=--new-window",
                "--web-browser-flag=--window-size=1440,900",
                "--dart-define=AUTHORIZED_EMAILS=rindler.eli@gmail.com,nguye2cy@mail.uc.edu,voltaicstestuser1@gmail.com"
